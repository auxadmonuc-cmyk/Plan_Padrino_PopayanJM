rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Administrador"
      );
    }

    function isAdminOrNoRestriction() {
      // Allow if admin, OR if users collection is empty (initial setup)
      return isSignedIn() && (
        isAdmin() ||
        !exists(/databases/$(database)/documents/users/admin)
      );
    }

    // Helper to extract incoming record data
    function incoming() {
      return request.resource.data;
    }

    // Helper to validate model string ID format
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !incoming().diff(resource.data).changedKeys().hasAny(['role'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 2. Collaborators Collection
    match /collaborators/{collaboratorId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(collaboratorId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // 3. Audit logs collection
    match /auditLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId);
      allow update, delete: if false;
    }

    // 4. Padrinos Collection
    match /padrinos/{padrinoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(padrinoId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

  }
}
